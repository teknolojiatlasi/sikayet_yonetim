<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!-- ===================== ROLLER ===================== -->
    <changeSet id="seed-roller" author="codex">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM roller WHERE kod = 'ROLE_ADMIN'
            </sqlCheck>
        </preConditions>

        <insert tableName="roller">
            <column name="kod" value="ROLE_ADMIN"/>
            <column name="ad" value="Admin"/>
            <column name="created_at" valueDate="2026-04-04T00:00:00"/>
            <column name="active" valueBoolean="true"/>
        </insert>

        <insert tableName="roller">
            <column name="kod" value="ROLE_OPERATOR"/>
            <column name="ad" value="Operator"/>
            <column name="created_at" valueDate="2026-04-04T00:00:00"/>
            <column name="active" valueBoolean="true"/>
        </insert>

        <insert tableName="roller">
            <column name="kod" value="ROLE_INCELEYEN"/>
            <column name="ad" value="Inceleyen"/>
            <column name="created_at" valueDate="2026-04-04T00:00:00"/>
            <column name="active" valueBoolean="true"/>
        </insert>
    </changeSet>


    <!-- ===================== YETKİLER ===================== -->
    <changeSet id="seed-yetkiler" author="codex">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM yetkiler WHERE kod = 'USER_VIEW'
            </sqlCheck>
        </preConditions>

        <insert tableName="yetkiler"><column name="kod" value="USER_VIEW"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="yetkiler"><column name="kod" value="USER_CREATE"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="yetkiler"><column name="kod" value="SIKAYET_VIEW"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="yetkiler"><column name="kod" value="SIKAYET_CREATE"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="yetkiler"><column name="kod" value="SIKAYET_ASSIGN"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="yetkiler"><column name="kod" value="SIKAYET_STATUS_CHANGE"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="yetkiler"><column name="kod" value="SIKAYET_RESULT_CREATE"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="yetkiler"><column name="kod" value="DOSYA_UPLOAD"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="yetkiler"><column name="kod" value="LOG_VIEW"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
    </changeSet>


    <!-- ===================== ADMIN USER ===================== -->
    <changeSet id="seed-admin-user" author="codex">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM kullanicilar WHERE kullanici_adi = 'admin'
            </sqlCheck>
        </preConditions>

        <insert tableName="kullanicilar">
            <column name="kullanici_adi" value="admin"/>
            <column name="email" value="admin@sikayet.local"/>
            <column name="sifre_hash" value="{noop}admin"/>
            <column name="ad" value="Sistem"/>
            <column name="soyad" value="Yoneticisi"/>
            <column name="created_at" valueDate="2026-04-04T00:00:00"/>
            <column name="active" valueBoolean="true"/>
        </insert>
    </changeSet>


    <!-- ===================== DURUMLAR ===================== -->
    <changeSet id="seed-durumlar" author="codex">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM sikayet_durumlari WHERE kod = 'YENI'
            </sqlCheck>
        </preConditions>

        <insert tableName="sikayet_durumlari"><column name="kod" value="YENI"/><column name="ad" value="Yeni"/><column name="final_durum" valueBoolean="false"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="sikayet_durumlari"><column name="kod" value="ATANDI"/><column name="ad" value="Atandi"/><column name="final_durum" valueBoolean="false"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="sikayet_durumlari"><column name="kod" value="INCELEMEDE"/><column name="ad" value="Incelemede"/><column name="final_durum" valueBoolean="false"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="sikayet_durumlari"><column name="kod" value="EK_BILGI_BEKLENIYOR"/><column name="ad" value="Ek Bilgi Bekleniyor"/><column name="final_durum" valueBoolean="false"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="sikayet_durumlari"><column name="kod" value="SONUCLANDI"/><column name="ad" value="Sonuclandi"/><column name="final_durum" valueBoolean="true"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="sikayet_durumlari"><column name="kod" value="KAPATILDI"/><column name="ad" value="Kapatildi"/><column name="final_durum" valueBoolean="true"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
    </changeSet>


    <!-- ===================== TÜRLER ===================== -->
    <changeSet id="seed-turler" author="codex">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM sikayet_turleri WHERE kod = 'HIZMET'
            </sqlCheck>
        </preConditions>

        <insert tableName="sikayet_turleri"><column name="kod" value="HIZMET"/><column name="ad" value="Hizmet Sikayeti"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
        <insert tableName="sikayet_turleri"><column name="kod" value="PERSONEL"/><column name="ad" value="Personel Sikayeti"/><column name="created_at" valueDate="2026-04-04T00:00:00"/><column name="active" valueBoolean="true"/></insert>
    </changeSet>

</databaseChangeLog>