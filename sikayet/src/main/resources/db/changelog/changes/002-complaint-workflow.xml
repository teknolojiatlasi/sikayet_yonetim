            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="sikayet_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="orijinal_dosya_adi" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="sistem_dosya_adi" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="dosya_yolu" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="mime_type" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="dosya_boyutu" type="BIGINT"><constraints nullable="false"/></column>
            <column name="yukleyen_kullanici_id" type="BIGINT"/>
            <column name="created_at" type="DATETIME"><constraints nullable="false"/></column>
            <column name="updated_at" type="DATETIME"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
            <column name="active" type="BIT" defaultValueBoolean="true"><constraints nullable="false"/></column>
        </createTable>
        <addForeignKeyConstraint baseTableName="sikayet_dosyalari" baseColumnNames="sikayet_id" referencedTableName="sikayetler" referencedColumnNames="id" constraintName="fk_dosya_sikayet"/>
        <addForeignKeyConstraint baseTableName="sikayet_dosyalari" baseColumnNames="yukleyen_kullanici_id" referencedTableName="kullanicilar" referencedColumnNames="id" constraintName="fk_dosya_kullanici"/>
    </changeSet>

