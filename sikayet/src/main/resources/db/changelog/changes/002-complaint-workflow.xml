            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
            <column name="active" type="BIT" defaultValueBoolean="true"><constraints nullable="false"/></column>
        </createTable>
        <addForeignKeyConstraint baseTableName="sikayet_loglari" baseColumnNames="sikayet_id" referencedTableName="sikayetler" referencedColumnNames="id" constraintName="fk_log_sikayet"/>

        <createTable tableName="sikayet_sonuclari">
