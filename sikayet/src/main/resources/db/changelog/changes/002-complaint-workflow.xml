<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="007-sikayet-turleri" author="codex">
        <createTable tableName="sikayet_turleri">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="kod" type="VARCHAR(50)"><constraints nullable="false" unique="true"/></column>
            <column name="ad" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="aciklama" type="VARCHAR(255)"/>
            <column name="created_at" type="DATETIME"><constraints nullable="false"/></column>
            <column name="updated_at" type="DATETIME"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
            <column name="active" type="BIT" defaultValueBoolean="true"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="008-sikayet-durumlari" author="codex">
        <createTable tableName="sikayet_durumlari">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="kod" type="VARCHAR(50)"><constraints nullable="false" unique="true"/></column>
            <column name="ad" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="final_durum" type="BIT" defaultValueBoolean="false"><constraints nullable="false"/></column>
            <column name="created_at" type="DATETIME"><constraints nullable="false"/></column>
            <column name="updated_at" type="DATETIME"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
            <column name="active" type="BIT" defaultValueBoolean="true"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <changeSet id="009-sikayetler" author="codex">
        <createTable tableName="sikayetler">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="sikayet_no" type="VARCHAR(50)"><constraints nullable="false" unique="true"/></column>
            <column name="kisi_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="sikayet_turu_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="sikayet_durumu_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="konu" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="aciklama" type="TEXT"><constraints nullable="false"/></column>
            <column name="oncelik" type="VARCHAR(50)"/>
            <column name="created_at" type="DATETIME"><constraints nullable="false"/></column>
            <column name="updated_at" type="DATETIME"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
            <column name="active" type="BIT" defaultValueBoolean="true"><constraints nullable="false"/></column>
        </createTable>
        <createIndex tableName="sikayetler" indexName="idx_sikayet_no"><column name="sikayet_no"/></createIndex>
        <addForeignKeyConstraint baseTableName="sikayetler" baseColumnNames="kisi_id" referencedTableName="kisiler" referencedColumnNames="id" constraintName="fk_sikayet_kisi"/>
        <addForeignKeyConstraint baseTableName="sikayetler" baseColumnNames="sikayet_turu_id" referencedTableName="sikayet_turleri" referencedColumnNames="id" constraintName="fk_sikayet_tur"/>
        <addForeignKeyConstraint baseTableName="sikayetler" baseColumnNames="sikayet_durumu_id" referencedTableName="sikayet_durumlari" referencedColumnNames="id" constraintName="fk_sikayet_durum"/>
    </changeSet>

    <changeSet id="010-sikayet-ekleri" author="codex">
