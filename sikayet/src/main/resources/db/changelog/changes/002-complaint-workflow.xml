        <addForeignKeyConstraint baseTableName="sikayet_atamalari" baseColumnNames="sikayet_id" referencedTableName="sikayetler" referencedColumnNames="id" constraintName="fk_atama_sikayet"/>
        <addForeignKeyConstraint baseTableName="sikayet_atamalari" baseColumnNames="atanan_kullanici_id" referencedTableName="kullanicilar" referencedColumnNames="id" constraintName="fk_atama_kullanici"/>

